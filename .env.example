# Launchpad.Trade API key — get it at https://launchpad.trade
LAUNCHPAD_API_KEY=your_api_key_here

# Main wallet private key (base58)
MAIN_PRIVATE_KEY=your_private_key_here

# Solana RPC WebSocket — get a free key at https://www.helius.dev
SOLANA_WSS=wss://mainnet.helius-rpc.com/?api-key=your_helius_key_here
